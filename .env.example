# Gateway
GATEWAY_HOST=0.0.0.0
GATEWAY_PORT=9090

# Backend Services
PIXORA_BACKEND_URL=https://pixora-backend.koyeb.app
CLOCKWERK_MEDIA_URL=https://clockwerk-media.koyeb.app

# JWT (sama dengan semua services)
JWT_SECRET=your_jwt_secret_here

# Redis
REDIS_URL=redis://localhost:6379

# Rate Limiting
RATE_LIMIT_PUBLIC=60
RATE_LIMIT_AUTHENTICATED=600
RATE_LIMIT_UPLOAD=30

# Timeouts (seconds)
PROXY_TIMEOUT_DEFAULT=30
PROXY_TIMEOUT_UPLOAD=300
PROXY_TIMEOUT_DOWNLOAD=300

# Logging
LOG_LEVEL=info
